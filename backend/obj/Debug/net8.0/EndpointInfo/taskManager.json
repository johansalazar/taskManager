{
  "openapi": "3.0.1",
  "info": {
    "title": "taskManager",
    "version": "1.0"
  },
  "paths": {
    "/api/Proyectos": {
      "get": {
        "tags": [
          "Proyectos"
        ],
        "summary": "Obtiene la lista de todos los proyectos",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Proyecto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Proyectos"
        ],
        "summary": "Crea un nuevo proyecto",
        "requestBody": {
          "description": "Datos del proyecto",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProyectoDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/ProyectoDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/ProyectoDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Proyecto"
                }
              }
            }
          }
        }
      }
    },
    "/api/Proyectos/{id}": {
      "get": {
        "tags": [
          "Proyectos"
        ],
        "summary": "Obtiene un proyecto por su ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID del proyecto",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Proyecto"
                }
              }
            }
          }
        }
      }
    },
    "/api/Tareas/estado/{estado}": {
      "get": {
        "tags": [
          "Tareas"
        ],
        "summary": "Obtiene las tareas filtradas por estado",
        "parameters": [
          {
            "name": "estado",
            "in": "path",
            "description": "Estado de la tarea. Valores posibles:\r\nPendiente, EnProgreso, Completada",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Tareas": {
      "post": {
        "tags": [
          "Tareas"
        ],
        "summary": "Crea una nueva tarea",
        "requestBody": {
          "description": "Datos de la tarea",
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TareaDTO"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/TareaDTO"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/TareaDTO"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/api/Tareas/{id}": {
      "get": {
        "tags": [
          "Tareas"
        ],
        "summary": "Obtiene una tarea por su ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "ID de la tarea",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    }
